# Database
# URL to connect to your database. Used by Prisma.
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# NextAuth.js
# A secret string used for signing and encrypting tokens. Generate a strong, random string.
# You can generate one with `openssl rand -base64 32` or `node -e "console.log(crypto.randomBytes(32).toString('base64'))"`
NEXTAUTH_process.env.SECRET_REDACTED

# Optional: OAuth Providers (e.g., Google, GitHub, etc.)
# If you're using Google for authentication:
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_process.env.SECRET_REDACTED

# Online Ordering System (e.g., Stripe)
# Stripe secret key for server-side operations.
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
# Stripe publishable key for client-side operations.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
# Stripe webhook secret for verifying webhook events.
STRIPE_WEBHOOK_process.env.SECRET_REDACTED

# Email Service (for order confirmations, reservations, contact forms)
# SMTP server details for sending emails.
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your_email_user"
EMAIL_SERVER_process.env.SECRET_REDACTED
EMAIL_FROM="noreply@ayaancafe.com"

# Google Maps API (for Contact & Location Page)
# Public API key for Google Maps JavaScript API.
NEXT_PUBLIC_GOOGLE_MAPS_process.env.SECRET_REDACTED

# Application URL
# The base URL of your application. Useful for absolute URLs in API routes, webhooks, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
